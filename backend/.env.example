DATABASE_URL=postgresql://transafrik:transafrik_secret@localhost:5432/transafrik
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000
# Production: add your Vercel URL, e.g. https://trans-afrik-remit.vercel.app
# Vercel preview/prod *.vercel.app origins are auto-allowed when ENVIRONMENT=production|staging
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.webp
SEED_ADMIN_EMAIL=admin@ipaygo.co.za
SEED_ADMIN_PASSWORD=Admin@TransAfrik2024!
SEED_COMPLIANCE_EMAIL=compliance@ipaygo.co.za
SEED_COMPLIANCE_PASSWORD=Compliance@TransAfrik2024!
SEED_CUSTOMER_EMAIL=customer@demo.co.za
SEED_CUSTOMER_PASSWORD=Customer@TransAfrik2024!
ENVIRONMENT=development
ENABLE_DEV_ENDPOINTS=true
DOCS_ENABLED=true

# Phase 6.1 — Redis
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_REDIS_ENABLED=true

# Phase 6.1 — Storage (local | s3)
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=af-south-1
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Phase 6.1 — Notifications
EMAIL_PROVIDER=smtp
SMS_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@transafrik.co.za
SENDGRID_API_KEY=
SES_REGION=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_SENDER_ID=TransAfrik

# Phase 6.1 — Webhook security
WEBHOOK_REPLAY_PROTECTION=true
WEBHOOK_IDEMPOTENCY_ENABLED=true
WEBHOOK_QUEUE_ENABLED=true
