# TransAfrik Remit Mobile — Environment Variables
# Copy to .env for local development

EXPO_PUBLIC_API_URL=https://api.ipaygo.co.za
EXPO_PUBLIC_APP_ENV=development

# Preview APK builds use EXPO_PUBLIC_APP_ENV=preview (set in eas.json preview profile)

# EAS Build (set in Expo dashboard or eas.json secrets)
# EAS_PROJECT_ID=
