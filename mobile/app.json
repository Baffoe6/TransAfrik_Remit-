{
  "expo": {
    "name": "TransAfrik Remit",
    "slug": "transafrik-remit",
    "version": "2.2.2",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B5E3B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.za.ipaygo.transafrik",
      "infoPlist": {
        "NSCameraUsageDescription": "Capture selfie for KYC verification",
        "NSPhotoLibraryUsageDescription": "Upload KYC documents"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B5E3B"
      },
      "package": "co.za.ipaygo.transafrik",
      "versionCode": 6,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1B5E3B"
        }
      ],
      "expo-local-authentication",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "Capture selfie for KYC verification"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TransAfrik Remit to access your photos for KYC document upload.",
          "cameraPermission": "Allow TransAfrik Remit to use the camera to capture KYC documents."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "apiUrl": "https://api.ipaygo.co.za",
      "eas": {
        "projectId": "fadbd8c6-4c8a-4dd6-b520-2ff6644a66c9"
      }
    },
    "owner": "baffoe6",
    "updates": {
      "url": "https://u.expo.dev/fadbd8c6-4c8a-4dd6-b520-2ff6644a66c9"
    }
  }
}
